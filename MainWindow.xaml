<Window x:Class="ST_Fumen_Manager_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ST_Fumen_Manager_WPF"
        mc:Ignorable="d"
        Title="ST-Fumen Manager WPF" Height="850" Width="1250"
        Background="#1E1E1E" Foreground="White"
        FontFamily="Segoe UI, Yu Gothic UI, Meiryo">

    <Window.Resources>
        <!-- Modern Button Style -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#3A3D40"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A4D50"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#2A2D30"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#2A2D30"/>
                    <Setter Property="Foreground" Value="#666666"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Primary Green Button -->
        <Style x:Key="GreenButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#2EA043"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3FB950"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#238636"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Danger Red Button -->
        <Style x:Key="RedButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#DA3633"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F85149"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#B62324"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid Style -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="#252526"/>
            <Setter Property="AlternatingRowBackground" Value="#2D2D30"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#3F3F46"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#333337"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#37373D"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TextBox inside DataGrid -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ComboBox Style (FIX: Explicit ControlTemplate to prevent white background on closed/selected state) -->
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" 
                                          Grid.Column="2" 
                                          Focusable="false"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border" 
                                                Background="#3C3C3C" 
                                                BorderBrush="#555555" 
                                                BorderThickness="1" 
                                                CornerRadius="3">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <Path x:Name="Arrow" 
                                                      Grid.Column="1" 
                                                      Fill="#CCCCCC" 
                                                      HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center" 
                                                      Data="M 0 0 L 4 4 L 8 0 Z"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="true">
                                                <Setter TargetName="Border" Property="Background" Value="#4C4C4C"/>
                                                <Setter TargetName="Arrow" Property="Fill" Value="White"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="true">
                                                <Setter TargetName="Border" Property="Background" Value="#505050"/>
                                                <Setter TargetName="Arrow" Property="Fill" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" 
                                              IsHitTestVisible="False" 
                                              Content="{TemplateBinding SelectionBoxItem}" 
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" 
                                              Margin="8,4,24,4" 
                                              VerticalAlignment="Center" 
                                              HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup" 
                                   Placement="Bottom" 
                                   IsOpen="{TemplateBinding IsDropDownOpen}" 
                                   AllowsTransparency="True" 
                                   Focusable="False" 
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown" 
                                      SnapsToDevicePixels="True" 
                                      MinWidth="{TemplateBinding ActualWidth}" 
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" 
                                            Background="#2D2D30" 
                                            BorderThickness="1" 
                                            BorderBrush="#555555"/>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBoxItem Style (FIX: Explicit ControlTemplate to block Windows system highlights) -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Border" Padding="8,5" Background="#3C3C3C" CornerRadius="2" Margin="2">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#505050"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2EA043"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsHighlighted" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Border" Property="Background" Value="#3FB950"/>
                                <Setter Property="Foreground" Value="White"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TabControl Modern Style -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                BorderBrush="#3F3F46" BorderThickness="1,1,1,0" 
                                CornerRadius="6,6,0,0" Padding="{TemplateBinding Padding}" Margin="0,0,4,0">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#252526"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#38383C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Control Bar -->
        <Border Grid.Row="0" Background="#252526" CornerRadius="8" Padding="12" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="フォルダ選択" Click="SelectFolder_Click" Margin="0,0,10,0" Width="110"/>
                <Button Grid.Column="1" Content="全件保存 (TJA)" Click="SaveAll_Click" Style="{StaticResource GreenButtonStyle}" Width="120"/>
                
                <TextBlock x:Name="StatusLabel" Grid.Column="2" 
                           Text="フォルダを選択してください" 
                           VerticalAlignment="Center" Margin="16,0,0,0" 
                           FontSize="14" FontWeight="SemiBold" Foreground="#A6A6A6"/>
            </Grid>
        </Border>

        <!-- Content Area with Tabs -->
        <TabControl Grid.Row="1">
            <!-- Tab 1: TJA編集 -->
            <TabItem Header="TJA編集">
                <Border Background="#252526" CornerRadius="0,0,8,8" Padding="1">
                    <DataGrid x:Name="CourseDataGrid" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="TITLE" Width="220">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="SUBTITLE" Width="160">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Subtitle, UpdateSourceTrigger=PropertyChanged}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="GENRE" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedItem="{Binding Genre, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemsSource="{Binding DataContext.GenreOptions, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="STAGE" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedItem="{Binding Stage, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemsSource="{Binding DataContext.StageOptions, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="COURSE" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedItem="{Binding SelectedCourse, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemsSource="{Binding Courses}"
                                                  DisplayMemberPath="CourseName"
                                                  Foreground="#FFD700" FontWeight="Bold"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="LV" Width="45">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding SelectedCourse.Level, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="MAKER" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Maker, UpdateSourceTrigger=PropertyChanged}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="COMBO" Width="65">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SelectedCourse.Combo}" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="GIMICK" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SelectedCourse.GimmickText}" FontWeight="Bold" Foreground="#FF5252" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="保存" Click="SaveRow_Click" Width="60" Height="26" Padding="0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>

            <!-- Tab 2: STFDB編集 -->
            <TabItem Header="STFDB編集">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- STFDB Selection Row -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="300"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="STFDBファイル:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14" FontWeight="Bold"/>
                        <ComboBox x:Name="StfdbComboBox" Grid.Column="1" SelectionChanged="StfdbComboBox_SelectionChanged"/>
                        <TextBlock x:Name="StfdbStatusText" Grid.Column="2" VerticalAlignment="Center" Margin="16,0,0,0" Foreground="#AAAAAA"/>
                    </Grid>

                    <!-- STFDB Operations Row -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="読み込み済みTJAから追加" Click="StfdbAddFromLoaded_Click" Margin="0,0,8,0"/>
                        <Button Content="ファイルから追加" Click="StfdbAddFromFile_Click" Margin="0,0,8,0"/>
                        <Button Content="選択行を削除" Click="StfdbDeleteSelected_Click" Style="{StaticResource RedButtonStyle}" Margin="0,0,16,0"/>
                        
                        <Button Content="上へ" Click="StfdbMoveUp_Click" Width="60" Margin="0,0,6,0"/>
                        <Button Content="下へ" Click="StfdbMoveDown_Click" Width="60" Margin="0,0,16,0"/>
                        
                        <Button Content="存在チェック" Click="StfdbValidate_Click" Margin="0,0,16,0"/>
                        <Button Content="STFDB保存" Click="StfdbSave_Click" Style="{StaticResource GreenButtonStyle}" Width="120"/>
                    </StackPanel>

                    <!-- STFDB Entries DataGrid -->
                    <Border Grid.Row="2" Background="#1E1E1E" CornerRadius="6" Padding="1">
                        <DataGrid x:Name="StfdbDataGrid" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" SelectionMode="Single"
                                  CellEditEnding="StfdbDataGrid_CellEditEnding">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="No" Binding="{Binding RowNumber}" Width="40" IsReadOnly="True"/>
                                
                                <DataGridTemplateColumn Header="状態" Width="70">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Severity}" FontWeight="Bold" HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Severity}" Value="OK">
                                                                <Setter Property="Foreground" Value="#2EA043"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                                                <Setter Property="Foreground" Value="#FFA500"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Severity}" Value="Error">
                                                                <Setter Property="Foreground" Value="#FF5252"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="メッセージ" Binding="{Binding Message}" Width="160" IsReadOnly="True"/>
                                <DataGridTextColumn Header="TITLE" Binding="{Binding Title}" Width="200" IsReadOnly="True"/>
                                <DataGridTextColumn Header="GENRE" Binding="{Binding Genre}" Width="120" IsReadOnly="True"/>
                                <DataGridTextColumn Header="COURSE" Binding="{Binding Course}" Width="80" IsReadOnly="True"/>
                                <DataGridTextColumn Header="LEVEL" Binding="{Binding Level}" Width="50" IsReadOnly="True"/>
                                
                                <DataGridTemplateColumn Header="TJAパス (直接編集可)" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding EditedPath}" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding EditedPath, UpdateSourceTrigger=PropertyChanged}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>
            <!-- Tab 3: STMD編集 -->
            <TabItem Header="STMD編集">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="300"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="STFDBファイル:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14" FontWeight="Bold"/>
                        <ComboBox x:Name="StmdComboBox" Grid.Column="1" SelectionChanged="StmdComboBox_SelectionChanged"/>
                        <Button Grid.Column="2" Content="STMD保存" Click="StmdSave_Click" Style="{StaticResource GreenButtonStyle}" Width="120" Margin="12,0,0,0"/>
                        <TextBlock x:Name="StmdStatusText" Grid.Column="3" VerticalAlignment="Center" Margin="16,0,0,0" Foreground="#AAAAAA"/>
                    </Grid>

                    <Border Grid.Row="1" Background="#1E1E1E" CornerRadius="6" Padding="1">
                        <DataGrid x:Name="StmdDataGrid" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="No" Binding="{Binding RowNumber}" Width="40" IsReadOnly="True"/>
                                <DataGridTextColumn Header="TJAパス" Binding="{Binding TjaPath}" Width="260" IsReadOnly="True"/>

                                <DataGridTemplateColumn Header="TITLE" Width="220">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="SUBTITLE" Width="180">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Subtitle, UpdateSourceTrigger=PropertyChanged}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="GENRE" Width="140">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox SelectedItem="{Binding Genre, UpdateSourceTrigger=PropertyChanged}"
                                                      ItemsSource="{Binding DataContext.GenreOptions, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="STAGE" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox SelectedItem="{Binding Stage, UpdateSourceTrigger=PropertyChanged}"
                                                      ItemsSource="{Binding DataContext.StageOptions, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="ORDER" Width="70">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Order, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="メッセージ" Binding="{Binding Message}" Width="180" IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tab 4: 公式順STFDB生成 -->
            <TabItem Header="公式順STFDB生成">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: Git / Database 操作ボタン -->
                    <Border Grid.Row="0" Background="#2D2D30" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="BtnGitFetch" Content="📥 Git曲データ取得/更新" Click="BtnGitFetch_Click"
                                        Margin="0,0,6,0" Padding="12,6"/>
                                <Button x:Name="BtnGitCancel" Content="⏹ キャンセル" Click="BtnGitCancel_Click"
                                        Style="{StaticResource RedButtonStyle}"
                                        Margin="0,0,16,0" Padding="10,6"
                                        IsEnabled="False"/>
                                <Button x:Name="BtnDbFetch" Content="🌐 Database取得/更新" Click="BtnDbFetch_Click"
                                        Margin="0,0,16,0" Padding="12,6"/>
                                <TextBlock x:Name="TxtGitElapsed" VerticalAlignment="Center"
                                           Foreground="#FFD700" FontSize="12" FontFamily="Consolas"
                                           Margin="0,0,12,0"/>
                                <TextBlock x:Name="TxtDbCacheInfo" VerticalAlignment="Center"
                                           Foreground="#888888" FontSize="12"/>
                            </StackPanel>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Git取得先フォルダ:" VerticalAlignment="Center"
                                           Margin="0,0,8,0" FontWeight="SemiBold"/>
                                <TextBox x:Name="TxtGitCloneFolder" Grid.Column="1"
                                         IsReadOnly="True" Margin="0,0,8,0" VerticalContentAlignment="Center"
                                         Height="28"/>
                                <Button x:Name="BtnGitCloneFolderBrowse" Grid.Column="2" Content="参照..." Click="BtnGitCloneFolderBrowse_Click"
                                        Margin="0,0,6,0" Padding="10,4"/>
                                <Button x:Name="BtnGitCloneFolderDefault" Grid.Column="3" Content="既定" Click="BtnGitCloneFolderDefault_Click"
                                        Padding="10,4"/>
                            </Grid>
                        </StackPanel>
                    </Border>


                    <!-- Row 1: フォルダ選択 -->
                    <Border Grid.Row="1" Background="#2D2D30" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- 曲データフォルダ -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="曲データフォルダ:" VerticalAlignment="Center"
                                       Margin="0,0,8,0" FontWeight="SemiBold"/>
                            <TextBox x:Name="TxtSrcFolder" Grid.Row="0" Grid.Column="1"
                                     IsReadOnly="True" Margin="0,0,8,0" VerticalContentAlignment="Center"
                                     Height="28"/>
                            <Button Grid.Row="0" Grid.Column="2" Content="参照..." Click="BtnSrcBrowse_Click"
                                    Padding="10,4"/>

                            <!-- 出力Songsフォルダ -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="出力Songsフォルダ:" VerticalAlignment="Center"
                                       Margin="0,0,8,0" FontWeight="SemiBold"/>
                            <TextBox x:Name="TxtDestFolder" Grid.Row="2" Grid.Column="1"
                                     IsReadOnly="True" Margin="0,0,8,0" VerticalContentAlignment="Center"
                                     Height="28"/>
                            <Button Grid.Row="2" Grid.Column="2" Content="参照..." Click="BtnDestBrowse_Click"
                                    Padding="10,4"/>
                        </Grid>
                    </Border>

                    <!-- Row 2: 操作ボタン + オプション -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button x:Name="BtnPreview" Content="🔍 照合プレビュー" Click="BtnPreview_Click"
                                Style="{StaticResource GreenButtonStyle}" Margin="0,0,8,0" Padding="14,7"/>
                        <Button x:Name="BtnGenerate" Content="💾 official.stfdb生成" Click="BtnGenerate_Click"
                                Margin="0,0,16,0" Padding="14,7"/>
                        <CheckBox x:Name="ChkIncludeWarning" Content="Warningも出力する"
                                  VerticalAlignment="Center" Foreground="#CCCCCC" Margin="0,0,16,0"/>
                        <CheckBox x:Name="ChkGenerateGoodbye" Content="サヨナラ曲フォルダも生成"
                                  VerticalAlignment="Center" Foreground="#CCCCCC" Margin="0,0,16,0"/>
                        <CheckBox x:Name="ChkGenerateConsumerCandidate" Content="CS限定楽曲フォルダも生成"
                                  VerticalAlignment="Center" Foreground="#CCCCCC" Margin="0,0,16,0"/>
                        <TextBlock x:Name="TxtOfficialStatus" VerticalAlignment="Center"
                                   Foreground="#A6A6A6" FontSize="12"/>
                    </StackPanel>

                    <!-- Row 3: ログ出力 (折りたたみ可) -->
                    <Border Grid.Row="3" Background="#1A1A1A" CornerRadius="4" Padding="6" Margin="0,0,0,6"
                            Height="80">
                        <ScrollViewer x:Name="OfficialLogScroll" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="TxtOfficialLog" TextWrapping="Wrap"
                                       Foreground="#BBBBBB" FontSize="11"
                                       FontFamily="Consolas, Lucida Console"/>
                        </ScrollViewer>
                    </Border>

                    <!-- Row 4: 照合プレビュー DataGrid -->
                    <Border Grid.Row="4" Background="#1E1E1E" CornerRadius="6" Padding="1">
                        <DataGrid x:Name="OfficialPreviewGrid"
                                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                                  SelectionMode="Single" IsReadOnly="False">
                            <DataGrid.Columns>
                                <!-- 状態 (色付き) -->
                                <DataGridTemplateColumn Header="状態" Width="75">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding StatusText}" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StatusText}" Value="OK">
                                                                <Setter Property="Foreground" Value="#2EA043"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusText}" Value="Warning">
                                                                <Setter Property="Foreground" Value="#FFA500"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusText}" Value="Unmatched">
                                                                <Setter Property="Foreground" Value="#FF5252"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusText}" Value="Duplicate">
                                                                <Setter Property="Foreground" Value="#E040FB"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusText}" Value="Error">
                                                                <Setter Property="Foreground" Value="#FF1744"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="出力先" Width="105">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{Binding OutputTargetOptions}"
                                                      DisplayMemberPath="Label"
                                                      SelectedValuePath="Value"
                                                      SelectedValue="{Binding OutputTarget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      IsEnabled="{Binding IsOutputTargetSelectable}"
                                                      SelectionChanged="OfficialOutputTarget_SelectionChanged"
                                                      MinWidth="92"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="公式ジャンル" Binding="{Binding OfficialGenre}" Width="120" IsReadOnly="True"/>
                                <DataGridTextColumn Header="公式順" Binding="{Binding OfficialOrder}" Width="55" IsReadOnly="True"/>
                                <DataGridTextColumn Header="公式TITLE" Binding="{Binding OfficialTitle}" Width="180" IsReadOnly="True"/>
                                <DataGridTextColumn Header="公式SUBTITLE" Binding="{Binding OfficialSubtitle}" Width="130" IsReadOnly="True"/>
                                <DataGridTextColumn Header="TJA TITLE" Binding="{Binding TjaTitle}" Width="180" IsReadOnly="True"/>
                                <DataGridTextColumn Header="TJA SUBTITLE" Binding="{Binding TjaSubtitle}" Width="130" IsReadOnly="True"/>
                                <DataGridTextColumn Header="TJAパス" Binding="{Binding TjaPath}" Width="*" IsReadOnly="True"/>
                                <DataGridTextColumn Header="分類" Binding="{Binding Classification}" Width="110" IsReadOnly="True"/>
                                <DataGridTextColumn Header="分類理由" Binding="{Binding ClassificationReason}" Width="220" IsReadOnly="True"/>
                                <DataGridTextColumn Header="分類ソース" Binding="{Binding ClassificationSource}" Width="110" IsReadOnly="True"/>
                                <DataGridTextColumn Header="属性" Binding="{Binding Attributes}" Width="110" IsReadOnly="True"/>
                                <DataGridTextColumn Header="生成先STFDB" Binding="{Binding DestinationStfdb}" Width="180" IsReadOnly="True"/>
                                <DataGridTextColumn Header="マッチ方式" Binding="{Binding MatchMethodText}" Width="150" IsReadOnly="True"/>
                                <DataGridTextColumn Header="メッセージ" Binding="{Binding Message}" Width="200" IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Row 5: サマリー -->
                    <Border Grid.Row="5" Background="#252526" CornerRadius="4" Padding="8,4" Margin="0,4,0,0">
                        <TextBlock x:Name="TxtOfficialSummary" Foreground="#888888" FontSize="12"
                                   Text="照合プレビューを実行してください"/>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
